# ── Supabase credentials ──────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your project values.
# Find these in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# ── Setup steps ───────────────────────────────────────────────────────────────
# 1. Go to https://supabase.com → create a free project
# 2. Open SQL Editor → paste + run supabase/migrations/001_initial.sql
# 3. Copy Project URL + anon key from Settings → API into this file
# 4. Rename this file to .env.local
# 5. Run: npm install && npm run dev
